{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "User profile with configuration metadata.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique user ID from Auth"
        },
        "email": {
          "type": "string",
          "description": "User email address"
        },
        "displayName": {
          "type": "string",
          "description": "Display name of the user"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp"
        }
      },
      "required": ["uid", "email"]
    },
    "history": {
      "title": "Processed File History",
      "description": "Log of a PDF document processed by the user",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who processed the file"
        },
        "fileName": {
          "type": "string",
          "description": "The processed file name"
        },
        "toolName": {
          "type": "string",
          "description": "The tool used to process"
        },
        "size": {
          "type": "number",
          "description": "The size of the output file in bytes"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The processing timestamp"
        }
      },
      "required": ["userId", "fileName", "toolName", "createdAt"]
    }
  },
  "firestore": {
    "users": {
      "schema": "users",
      "description": "Global user profiles"
    },
    "users/{userId}/history": {
      "schema": "history",
      "description": "User-specific processed history tracking"
    }
  }
}
